"    double armAngle1_left = 351.959826;\n"
"    double velocity = 20;\n"
"    double acceleration = 20;\n"
"    robot.SetSpeed(10);     // 最大運動速度の設定\n"
"    robot.SetAccScale(10);  // 運動加速度の設定\n"
"    char errMsg[1024];\n"
"    ARMErrorCode rtnCode = robot.MoveJ(j0_left, velocity, acceleration, errMsg);  // 直線軌道の開始点へ移動\n"
