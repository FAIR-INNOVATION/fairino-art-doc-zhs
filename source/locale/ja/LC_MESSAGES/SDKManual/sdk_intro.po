"* @param [out] errMsg 错误信息打印\n"
"* @return 错误码\n"
"**/\n"
"ARMErrorCode MoveC(double* midCartPos, double midArmAngle, double* destCartPos, double destArmAngle, double velocity, double acceleration, char errMsg[1024]);"
msgstr ""
"/**\n"
" * @brief カルテシアン空間における円弧運動\n"
" * @param [in] midCartPos   中間点のカルテシアン位置・姿勢（単位：[mm deg]）\n"
" * @param [in] midArmAngle  中間点のロボットアームのアーム角（単位：deg）\n"
" * @param [in] destCartPos  目標点のカルテシアン位置・姿勢（単位：[mm deg]）\n"
" * @param [in] destArmAngle 目標点のロボットアームのアーム角（単位：deg）\n"
" * @param [in] velocity     速度パーセンテージ（範囲：[0–100]）\n"
" * @param [in] acceleration 加速度パーセンテージ（範囲：[0–100]、現時点では未対応）\n"
" * @param [out] errMsg      エラー情報の出力先\n"
" * @return エラーコード\n"
" **/\n"
"ARMErrorCode MoveC(double* midCartPos, double midArmAngle, double* destCartPos, double destArmAngle, double velocity, double acceleration, char errMsg[1024]);"

