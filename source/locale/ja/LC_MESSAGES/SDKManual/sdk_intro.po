#: ../../source/SDKManual/sdk_intro.rst:551
msgid "关节空间伺服模式运动-单臂"
msgstr "関節空間サーボモード運動－片腕"

#: ../../source/SDKManual/sdk_intro.rst:553
#, python-format
msgid ""
"int ServoJTest()\n"
"{\n"
"    SingleRobot robot(SingleRobot::ART3_R7, SingleRobot::LeftArm);        // 实例化机械臂\n"
"\n"
"    // 目标点点位信息\n"
"    double j1_left[7] = {10, 10, 10, 10, 10, -10, 10};\n"
"    double velocity = 20;\n"
"    double acceleration = 20;\n"
"    robot.SetSpeed(10);     // 设置最大运动速度\n"
"    robot.SetAccScale(10);  // 设置运动加速度\n"
"    char errMsg[1024];\n"
"    ARMErrorCode rtnCode = robot.MoveJ(j1_left, velocity, acceleration, errMsg);\n"
"    // if (rtnCode != ARMErrorCode::Success)\n"
"    // {\n"
"    //     return -1;\n"
"    // }\n"
"    // 判断是否运动完成\n"
"    while(true)\n"
"    {\n"
"        std::this_thread::sleep_for(std::chrono::milliseconds(1000));\n"
"        uint8_t state;\n"
"        robot.GetRobotMotionDone(state);\n"
"        if (state == 1)\n"
"        {\n"
"            break;\n"
"        }\n"
"    }\n"
"    printf(\"moveJ errorcode: %d\\n\", rtnCode);\n"
"\n"
"    int stepTime = 5;  // ms\n"
"    double speed = 5;\n"
"    double runTime = 1.0;  // s\n"
"    int totalNum = runTime*1000.0/stepTime;\n"
"    double nextJoint[7] = {0};\n"
"\n"
"    memset(errMsg, 0, 1024);\n"
"    rtnCode = robot.ServoMoveStart();\n"
"    if (rtnCode != ARMErrorCode::Success)\n"
"    {\n"
"        return -1;\n"
"    }\n"
"    for (int i = 0; i < totalNum; i++)\n"
"    {\n"
"        for (int j = 0; j < 7; j++)\n"
"        {\n"
"            nextJoint[j] = j1_left[j] + i*1.0/totalNum*speed;\n"
"        }\n"
"        rtnCode = robot.ServoJ(nextJoint, stepTime, errMsg);\n"
"        if (rtnCode != ARMErrorCode::Success)\n"
"        {\n"
"            std::cout << (int)rtnCode << std::endl;\n"
"            break;\n"
"        }\n"
"    }\n"
"    printf(\"servoJ errorcode: %d\\n\", rtnCode);\n"
"    rtnCode = robot.ServoMoveEnd();\n"
"    if (rtnCode != ARMErrorCode::Success)\n"
"    {\n"
"        return -1;\n"
"    }\n"
"\n"
"    return 0;\n"
"}"
msgstr ""
"int ServoJTest()\n"
"{\n"
"    SingleRobot robot(SingleRobot::ART3_R7, SingleRobot::LeftArm);        // ロボットアームのインスタンス化\n"
"\n"
"    // 目標位置の関節角度情報\n"
"    double j1_left[7] = {10, 10, 10, 10, 10, -10, 10};\n"
"    double velocity = 20;\n"
"    double acceleration = 20;\n"
"    robot.SetSpeed(10);     // 最大運動速度を設定\n"
"    robot.SetAccScale(10);  // 運動加速度を設定\n"
"    char errMsg[1024];\n"
"    ARMErrorCode rtnCode = robot.MoveJ(j1_left, velocity, acceleration, errMsg);\n"
"    // if (rtnCode != ARMErrorCode::Success)\n"
"    // {\n"
"    //     return -1;\n"
"    // }\n"
"    // 運動完了の判定\n"
"    while(true)\n"
"    {\n"
"        std::this_thread::sleep_for(std::chrono::milliseconds(1000));\n"
"        uint8_t state;\n"
"        robot.GetRobotMotionDone(state);\n"
"        if (state == 1)\n"
"        {\n"
"            break;\n"
"        }\n"
"    }\n"
"    printf(\"moveJ エラーコード: %d\\n\", rtnCode);\n"
"\n"
"    int stepTime = 5;  // ms\n"
"    double speed = 5;\n"
"    double runTime = 1.0;  // s\n"
"    int totalNum = static_cast<int>(runTime * 1000.0 / stepTime);\n"
"    double nextJoint[7] = {0};\n"
"\n"
"    memset(errMsg, 0, 1024);\n"
"    rtnCode = robot.ServoMoveStart();\n"
"    if (rtnCode != ARMErrorCode::Success)\n"
"    {\n"
"        return -1;\n"
"    }\n"
"    for (int i = 0; i < totalNum; i++)\n"
"    {\n"
"        for (int j = 0; j < 7; j++)\n"
"        {\n"
"            nextJoint[j] = j1_left[j] + i * 1.0 / totalNum * speed;\n"
"        }\n"
"        rtnCode = robot.ServoJ(nextJoint, stepTime, errMsg);\n"
"        if (rtnCode != ARMErrorCode::Success)\n"
"        {\n"
"            std::cout << static_cast<int>(rtnCode) << std::endl;\n"
"            break;\n"
"        }\n"
"    }\n"
"    printf(\"servoJ エラーコード: %d\\n\", rtnCode);\n"
"    rtnCode = robot.ServoMoveEnd();\n"
"    if (rtnCode != ARMErrorCode::Success)\n"
"    {\n"
"        return -1;\n"
"    }\n"
"\n"
"    return 0;\n"
"}"

