"    {\n"
"        return -1;\n"
"    }\n"
"    // 運動完了の確認\n"
"    while(true)\n"
"    {\n"
"        std::this_thread::sleep_for(std::chrono::milliseconds(1000));\n"
"        uint8_t state;\n"
"        robot.GetRobotMotionDone(state);\n"
"        if (state == 1)\n"
"        {\n"
"            break;\n"
"        }\n"
"    }\n"
"    printf(\"moveL エラーコード: %d\\n\", rtnCode);\n"
"\n"
"    return 0;\n"
"}"

