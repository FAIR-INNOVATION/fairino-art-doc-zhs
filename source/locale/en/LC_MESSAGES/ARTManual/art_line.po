#: ../../source/ARTManual/art_line.rst:85
msgid "名称：**注意**"
msgstr "Name: **Note**"

#: ../../source/ARTManual/art_line.rst:89
msgid "24V、48V供电电源请自备。"
msgstr "The 24V and 48V power supply are required to be provided by yourself."

#: ../../source/ARTManual/art_line.rst:90
msgid "上位机调试网线请自备。"
msgstr ""
"The host computer debugging network cable is required to be provided by "
"yourself."

#: ../../source/ARTManual/art_line.rst:91
msgid "控制器和分支器之间的网线请自备。"
msgstr ""
"The network cable between the controller and the distributor is required to "
"be prepared by yourself."
