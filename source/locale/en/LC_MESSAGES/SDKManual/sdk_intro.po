msgstr ""
"/**\n"
"* @brief Joint-space motion\n"
"* @param [in] destJointPos Target joint positions in degrees\n"
"* @param [in] velocity Velocity percentage, range [0–100]\n"
"* @param [in] acceleration Acceleration percentage, range [0–100]; currently not supported\n"
"* @param [out] errMsg Error message string\n"
"* @return Error code\n"
"**/\n"
"ARMErrorCode MoveJ(double* destJointPos, double velocity, double acceleration, char errMsg[1024]);"

#: ../../source/SDKManual/sdk_intro.rst:61
msgid "关节空间运动代码示例-单臂"
msgstr "Joint-Space Motion Code Example – Single Arm"

#: ../../source/SDKManual/sdk_intro.rst:63
#, python-format
msgid ""
"int MoveJTest()\n"
"{\n"
"    SingleRobot robot(SingleRobot::ART3_R7, SingleRobot::LeftArm);        // 实例化机械臂\n"
"\n"
"    // 目标点点位信息\n"
"    double j1_left[7] = {10, 10, 10, 10, 10, -10, 10};  // 点位数据仅供参考\n"
"    double velocity = 20;\n"
"    double acceleration = 20;\n"
"    robot.SetSpeed(10);     // 设置最大运动速度\n"
"    robot.SetAccScale(10);  // 设置运动加速度\n"
"    char errMsg[1024];\n"
"    ARMErrorCode rtnCode = robot.MoveJ(j1_left, velocity, acceleration, errMsg);\n"
"    if (rtnCode != ARMErrorCode::Success)\n"
"    {\n"
"        return -1;\n"
"    }\n"
"    // 判断是否运动完成\n"
"    while(true)\n"
"    {\n"
"        std::this_thread::sleep_for(std::chrono::milliseconds(1000));\n"
"        uint8_t state;\n"
"        robot.GetRobotMotionDone(state);\n"
"        if (state == 1)\n"
"        {\n"
"            break;\n"
"        }\n"
"    }\n"
"    printf(\"moveJ errorcode: %d\\n\", rtnCode);\n"
"\n"
"    return 0;\n"
"}"
msgstr ""
"int MoveJTest()\n"
"{\n"
"    SingleRobot robot(SingleRobot::ART3_R7, SingleRobot::LeftArm);        // Instantiate the robotic arm\n"
"\n"
"    // Target joint position data\n"
"    double j1_left[7] = {10, 10, 10, 10, 10, -10, 10};  // Joint position data is for reference only\n"
"    double velocity = 20;\n"
"    double acceleration = 20;\n"
"    robot.SetSpeed(10);     // Set maximum motion speed\n"
"    robot.SetAccScale(10);  // Set motion acceleration\n"
"    char errMsg[1024];\n"
"    ARMErrorCode rtnCode = robot.MoveJ(j1_left, velocity, acceleration, errMsg);\n"
"    if (rtnCode != ARMErrorCode::Success)\n"
"    {\n"
"        return -1;\n"
"    }\n"
"    // Check whether motion is complete\n"
"    while(true)\n"
"    {\n"
"        std::this_thread::sleep_for(std::chrono::milliseconds(1000));\n"
"        uint8_t state;\n"
"        robot.GetRobotMotionDone(state);\n"
"        if (state == 1)\n"
"        {\n"
"            break;\n"
"        }\n"
"    }\n"
"    printf(\"moveJ error code: %d\\n\", rtnCode);\n"
"\n"
"    return 0;\n"
"}"

