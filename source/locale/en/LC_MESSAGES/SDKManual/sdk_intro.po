#: ../../source/SDKManual/sdk_intro.rst:45
#: ../../source/SDKManual/sdk_intro.rst:1030
msgid "关节空间运动"
msgstr "Joint-space motion"

#: ../../source/SDKManual/sdk_intro.rst:47
#: ../../source/SDKManual/sdk_intro.rst:1032
msgid ""
"/**\n"
"* @brief  关节空间运动\n"
"* @param [in] destJointPos   目标点关节位置，单位deg\n"
"* @param [in] velocity 速度百分比，范围[0-100]\n"
"* @param [in] acceleration 加速度百分比，范围[0-100]，暂不开放\n"
"* @param [out] errMsg 错误信息打印\n"
